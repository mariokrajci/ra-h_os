{
    "manifest_version": 3,
    "name": "RA-H_OS",
    "version": "0.16",
    "description": "Save pages, selections, and chats to RA-OS.",
    "permissions": [
        "scripting",
        "activeTab",
        "tabs",
        "storage"
    ],
    "host_permissions": [
        "http://192.168.0.100:3001/*",
        "*://*/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_title": "Save to RA-OS"
    },
    "commands": {
        "_execute_action": {
            "suggested_key": {
                "default": "Ctrl+Shift+S",
                "mac": "Ctrl+S"
            },
            "description": "Save current page or selection to RA-OS"
        }
    },
    "options_page": "options.html"
}
